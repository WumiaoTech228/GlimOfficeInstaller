<Window x:Class="GOI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Title="Glim Office Installer"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Width="740"
        Height="715"
        ui:ThemeManager.RequestedTheme="Default"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        Icon="pack://application:,,,/GOI;component/Resources/icon.ico">

    <Window.Resources>
        <!-- Icon Font Resource -->
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>
    </Window.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部标题栏区域 (Translucent Glassmorphism) ===== -->
        <Border Grid.Row="0" Height="100" Background="{DynamicResource SystemControlTransientBackgroundBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Custom Fluent Logo Image -->
                <Image Grid.Column="0" Source="pack://application:,,,/GOI;component/Resources/logo.png" Width="36" Height="36" VerticalAlignment="Center" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Glim Office Installer" Style="{StaticResource TitleTextBlockStyle}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="轻量、纯净的一键 Office 部署配置工具" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 产品/大类切换 Tab (WinUI Segment Style) ===== -->
        <StackPanel Grid.Row="1" Margin="0,15,0,0">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Center" Height="40" Padding="3">
                <StackPanel Orientation="Horizontal">
                    <!-- Microsoft Office -->
                    <Border CornerRadius="6" Cursor="Hand" Width="130">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectMsOfficeCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMsOffice}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="MS Office" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundBrushSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMsOffice}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- WPS Office -->
                    <Border CornerRadius="6" Cursor="Hand" Width="130">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectWpsCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWps}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="WPS Office" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundBrushSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWps}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- 永中 Office -->
                    <Border CornerRadius="6" Cursor="Hand" Width="130">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectYozoCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsYozo}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="永中 Office" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundBrushSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsYozo}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- OnlyOffice -->
                    <Border CornerRadius="6" Cursor="Hand" Width="130">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectOnlyOfficeCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnlyOffice}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="OnlyOffice" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundBrushSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOnlyOffice}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- LibreOffice -->
                    <Border CornerRadius="6" Cursor="Hand" Width="130">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectLibreOfficeCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLibreOffice}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="LibreOffice" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundBrushSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLibreOffice}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ===== MS Office 版本卡片 (WinUI 3 Cards Style) ===== -->
        <Grid Grid.Row="2" Height="140" Margin="25,10,25,0"
              Visibility="{Binding IsMsOffice, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <!-- 左翻页 -->
            <Button Grid.Column="0" Width="36" Height="36"
                    Command="{Binding PrevGroupCommand}"
                    VerticalAlignment="Center" Cursor="Hand" HorizontalAlignment="Left"
                    Background="Transparent" BorderThickness="0"
                    ui:ControlHelper.CornerRadius="18">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LeftArrowVisible}" Value="False">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Path Data="M 8,0 L 0,5 L 8,10 Z" Fill="{DynamicResource TextControlForegroundBrush}" Stretch="Uniform" Width="8" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>

            <!-- 左卡片 (Office 2024) -->
            <Border Grid.Column="1" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LeftSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding Command="{Binding SelectLeftCommand}" MouseAction="LeftClick"/>
                </Border.InputBindings>
                <Grid VerticalAlignment="Center" Margin="20,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="28" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding LeftTitle}" Style="{StaticResource BodyTextBlockStyle}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LeftSub}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LeftDesc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushDisabled}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右卡片 (Microsoft 365) -->
            <Border Grid.Column="3" CornerRadius="8" BorderThickness="1.5" Cursor="Hand"
                    Visibility="{Binding RightVisible, Converter={StaticResource BoolToVisibility}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RightSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding Command="{Binding SelectRightCommand}" MouseAction="LeftClick"/>
                </Border.InputBindings>
                <Grid VerticalAlignment="Center" Margin="20,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE753;" FontFamily="{StaticResource IconFont}" FontSize="28" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding RightTitle}" Style="{StaticResource BodyTextBlockStyle}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RightSub}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RightDesc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushDisabled}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右翻页 -->
            <Button Grid.Column="4" Width="36" Height="36"
                    Command="{Binding NextGroupCommand}"
                    VerticalAlignment="Center" Cursor="Hand" HorizontalAlignment="Right"
                    Background="Transparent" BorderThickness="0"
                    ui:ControlHelper.CornerRadius="18">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RightArrowVisible}" Value="False">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Path Data="M 0,0 L 8,5 L 0,10 Z" Fill="{DynamicResource TextControlForegroundBrush}" Stretch="Uniform" Width="8" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- ===== WPS 版本卡片 ===== -->
        <Grid Grid.Row="2" Height="140" Margin="25,10,25,0"
              Visibility="{Binding IsWps, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- WPS 2023 -->
            <Border Grid.Column="0" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding SelectWps2023Command}" MouseAction="LeftClick"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Wps2023Selected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="WPS 2023" Style="{StaticResource BodyTextBlockStyle}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="专业版 12.1" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WPS 2019 -->
            <Border Grid.Column="2" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding SelectWps2019Command}" MouseAction="LeftClick"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Wps2019Selected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="WPS 2019" Style="{StaticResource BodyTextBlockStyle}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="专业版 11.8" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WPS 2016 -->
            <Border Grid.Column="4" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding SelectWps2016Command}" MouseAction="LeftClick"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Wps2016Selected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="WPS 2016" Style="{StaticResource BodyTextBlockStyle}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="专业版 10.8" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WPS 2013 -->
            <Border Grid.Column="6" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding SelectWps2013Command}" MouseAction="LeftClick"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Wps2013Selected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="WPS 2013" Style="{StaticResource BodyTextBlockStyle}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="专业版 9.1" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 永中版本卡片 ===== -->
        <Grid Grid.Row="2" Height="140" Margin="25,10,25,0"
              Visibility="{Binding IsYozo, Converter={StaticResource BoolToVisibility}}">
            <Border CornerRadius="8" BorderThickness="1.5" Cursor="Hand" HorizontalAlignment="Center" Width="200"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}">
                <Grid VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="永中Office" Style="{StaticResource BodyTextBlockStyle}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="个人版 (最新)" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== OnlyOffice 版本卡片 ===== -->
        <Grid Grid.Row="2" Height="140" Margin="25,10,25,0"
              Visibility="{Binding IsOnlyOffice, Converter={StaticResource BoolToVisibility}}">
            <Border CornerRadius="8" BorderThickness="1.5" Cursor="Hand" HorizontalAlignment="Center" Width="200"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}">
                <Grid VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="OnlyOffice" Style="{StaticResource BodyTextBlockStyle}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Desktop Editors" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== LibreOffice 版本卡片 ===== -->
        <Grid Grid.Row="2" Height="140" Margin="25,10,25,0"
              Visibility="{Binding IsLibreOffice, Converter={StaticResource BoolToVisibility}}">
            <Border CornerRadius="8" BorderThickness="1.5" Cursor="Hand" HorizontalAlignment="Center" Width="200"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}">
                <Grid VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="LibreOffice" Style="{StaticResource BodyTextBlockStyle}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="稳定版 26.2.4" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 区域标题 ===== -->
        <TextBlock Grid.Row="3" Text="选择需要包含的组件" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="14" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,26,0,8"
                   Visibility="{Binding IsMsOffice, Converter={StaticResource BoolToVisibility}}"/>

        <TextBlock Grid.Row="3" Text="部署信息说明" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="14" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,26,0,8"
                   Visibility="{Binding IsWps, Converter={StaticResource BoolToVisibility}}"/>

        <TextBlock Grid.Row="3" Text="部署信息说明" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="14" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,26,0,8"
                   Visibility="{Binding IsYozo, Converter={StaticResource BoolToVisibility}}"/>

        <TextBlock Grid.Row="3" Text="部署信息说明" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="14" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,26,0,8"
                   Visibility="{Binding IsOnlyOffice, Converter={StaticResource BoolToVisibility}}"/>

        <TextBlock Grid.Row="3" Text="部署信息说明" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="14" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,26,0,8"
                   Visibility="{Binding IsLibreOffice, Converter={StaticResource BoolToVisibility}}"/>

        <!-- ===== MS Office 组件面板 (Fluent Card container) ===== -->
        <Border Grid.Row="4" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Margin="25,5,25,0" Height="175"
                Visibility="{Binding IsMsOffice, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl ItemsSource="{Binding Components}" Margin="30,15,30,15">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="15,8"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ===== WPS 提示面板 ===== -->
        <Border Grid.Row="4" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Margin="25,5,25,0" Height="175"
                Visibility="{Binding IsWps, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="30,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="• 提供静默自动安装选项，已预设静默安装指令参数（/S）" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 企业专业版纯净无广告，更轻量，更稳定" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 安装包由高可用分发网络托管，极速下载安装" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 永中 提示面板 ===== -->
        <Border Grid.Row="4" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Margin="25,5,25,0" Height="175"
                Visibility="{Binding IsYozo, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="30,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="• 国内自主研发，深度适配中文排版规范与国标公文" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 静默自动安装，内置静默参数 /S" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 官方个人版镜像，安全无插件广告" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== OnlyOffice 提示面板 ===== -->
        <Border Grid.Row="4" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Margin="25,5,25,0" Height="175"
                Visibility="{Binding IsOnlyOffice, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="30,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="• 开源强大的协作办公套件，与 MS Office 格式高度兼容" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 命令行静默参数 /VERYSILENT /NORESTART" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 支持插件系统，本地快速部署，完全免费" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== LibreOffice 提示面板 ===== -->
        <Border Grid.Row="4" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Margin="25,5,25,0" Height="175"
                Visibility="{Binding IsLibreOffice, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="30,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="• 著名开源社区维护的顶级办公套件，极具稳定与纯净" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 采用 Windows Installer 规范，静默指令：msiexec /i ... /qn" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Text="• 企业无广告首选，支持开放文档标准（ODF）" Style="{StaticResource BodyTextBlockStyle}" FontSize="13" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 进度条 + 状态 ===== -->
        <StackPanel Grid.Row="5" Margin="25,18,25,12">
            <ProgressBar Height="4" Minimum="0" Maximum="100"
                         Value="{Binding DownloadProgress}"
                         Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource BodyTextBlockStyle}" FontSize="12"
                       Foreground="{DynamicResource TextControlForegroundBrushSecondary}" TextAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ===== 提示信息 ===== -->
        <TextBlock Grid.Row="5" Text="建议保持网络连接，以便完成激活过程" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Foreground="{DynamicResource TextControlForegroundBrushSecondary}" VerticalAlignment="Bottom" Margin="0,0,0,-8"/>

        <!-- ===== 按钮行 ===== -->
        <Grid Grid.Row="6" Margin="0,12,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 一键深层卸载 (Styled Fluent Red Danger Button) -->
            <Button Grid.Column="1" Content="一键深层卸载" Command="{Binding UninstallAllCommand}" 
                    Width="180" Height="40" FontSize="15" FontWeight="SemiBold"
                    Style="{StaticResource DefaultButtonStyle}"
                    Background="#A71D1D" Foreground="White" BorderThickness="0"
                    ui:ControlHelper.CornerRadius="8"/>

            <!-- 一键开始部署 (Styled Fluent Accent Primary Button) -->
            <Button Grid.Column="3" Content="一键开始部署" Command="{Binding InstallCommand}" 
                    Width="180" Height="40" FontSize="15" FontWeight="SemiBold"
                    Style="{StaticResource AccentButtonStyle}"
                    ui:ControlHelper.CornerRadius="8"/>
        </Grid>
    </Grid>
</Window>
