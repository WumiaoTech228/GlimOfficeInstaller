<Window x:Class="GOI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Title="Glim Office Installer"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Width="830"
        Height="730"
        ui:ThemeManager.RequestedTheme="Default"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:TitleBar.IsIconVisible="True"
        Icon="pack://application:,,,/GOI;component/Resources/icon.ico">

    <Window.Resources>
        <!-- Icon Font Resource -->
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

        <!-- Fluent 2.0 Borderless Icon Button Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SystemControlTransientBackgroundBrush}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SystemControlAltHighBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- Native Fluent NavigationView for Left Menu -->
        <ui:NavigationView x:Name="NavView"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="False"
                           SelectionChanged="NavigationView_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="MS Office" Tag="MsOffice">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/ms_office_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="WPS Office" Tag="Wps">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/wps_office_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="永中 Office" Tag="Yozo">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/yozo_office_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="OnlyOffice" Tag="OnlyOffice">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/onlyoffice_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="LibreOffice" Tag="LibreOffice">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/libreoffice_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <!-- NavigationView Right Content Pane -->
            <Grid Margin="20,10,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title / InfoBar -->
                    <RowDefinition Height="Auto"/> <!-- Cards Grid -->
                    <RowDefinition Height="Auto"/> <!-- Section Title -->
                    <RowDefinition Height="*"/>    <!-- Component List / Warning Board -->
                    <RowDefinition Height="Auto"/> <!-- Progress / Status -->
                    <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                </Grid.RowDefinitions>

                <!-- ROW 0: Header & Installed Detection InfoBar -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="pack://application:,,,/GOI;component/Resources/logo.png" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Grid.Column="1" Text="Glim Office Installer" Style="{StaticResource TitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding ArchText}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseLowBrush}" FontSize="10" VerticalAlignment="Center"/>
                    </Grid>
                    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                    
                    <!-- Native Fluent Warning InfoBar -->
                    <ui:InfoBar Title="检测到已安装版本"
                                Message="{Binding InstalledVersionText}"
                                IsOpen="{Binding IsInstalledWarningVisible}"
                                Severity="Warning"
                                IsClosable="False"
                                Margin="0,0,0,5"/>
                </StackPanel>

                <!-- ROW 1: Version Cards depending on selected type -->
                <Grid Grid.Row="1" Height="140">
                    <!-- 1. MS Office Cards Panel -->
                    <Grid Visibility="{Binding IsMsOffice, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左翻页 -->
                        <Button Grid.Column="0" Width="36" Height="36"
                                Command="{Binding PrevGroupCommand}"
                                VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LeftArrowVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Path Data="M 8,0 L 0,5 L 8,10 Z" Fill="{DynamicResource SystemControlPageTextBaseHighBrush}" Stretch="Uniform" Width="8" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- 左卡片 (Office 2024) -->
                        <Border Grid.Column="1" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LeftSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding SelectLeftCommand}" MouseAction="LeftClick"/>
                            </Border.InputBindings>
                            <Grid VerticalAlignment="Center" Margin="20,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="28" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding LeftTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding LeftSub}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding LeftDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseLowBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 右卡片 (Microsoft 365) -->
                        <Border Grid.Column="3" CornerRadius="8" BorderThickness="1.5" Cursor="Hand"
                                Visibility="{Binding RightVisible, Converter={StaticResource BoolToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RightSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding SelectRightCommand}" MouseAction="LeftClick"/>
                            </Border.InputBindings>
                            <Grid VerticalAlignment="Center" Margin="20,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE753;" FontFamily="{StaticResource IconFont}" FontSize="28" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding RightTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RightSub}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RightDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseLowBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 右翻页 -->
                        <Button Grid.Column="4" Width="36" Height="36"
                                Command="{Binding NextGroupCommand}"
                                VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RightArrowVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Path Data="M 0,0 L 8,5 L 0,10 Z" Fill="{DynamicResource SystemControlPageTextBaseHighBrush}" Stretch="Uniform" Width="8" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- 2. WPS Office Cards Panel -->
                    <Grid Visibility="{Binding IsWps, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- WPS 2023 -->
                        <Border Grid.Column="0" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding SelectWps2023Command}" MouseAction="LeftClick"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Wps2023Selected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="WPS 2023" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="专业版 12.1" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- WPS 2019 -->
                        <Border Grid.Column="2" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding SelectWps2019Command}" MouseAction="LeftClick"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Wps2019Selected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="WPS 2019" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="专业版 11.8" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- WPS 2016 -->
                        <Border Grid.Column="4" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding SelectWps2016Command}" MouseAction="LeftClick"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Wps2016Selected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="WPS 2016" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="专业版 10.8" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- WPS 2013 -->
                        <Border Grid.Column="6" CornerRadius="8" BorderThickness="1.5" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding SelectWps2013Command}" MouseAction="LeftClick"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Wps2013Selected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="WPS 2013" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="专业版 9.1" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 3. Yozo Office Cards Panel -->
                    <Grid Visibility="{Binding IsYozo, Converter={StaticResource BoolToVisibility}}">
                        <Border CornerRadius="8" BorderThickness="1.5" Cursor="Hand" HorizontalAlignment="Center" Width="240"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}">
                            <Grid VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="永中Office" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="个人版 9.0" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 4. OnlyOffice Cards Panel -->
                    <Grid Visibility="{Binding IsOnlyOffice, Converter={StaticResource BoolToVisibility}}">
                        <Border CornerRadius="8" BorderThickness="1.5" Cursor="Hand" HorizontalAlignment="Center" Width="240"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}">
                            <Grid VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="OnlyOffice" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Desktop Editors" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 5. LibreOffice Cards Panel -->
                    <Grid Visibility="{Binding IsLibreOffice, Converter={StaticResource BoolToVisibility}}">
                        <Border CornerRadius="8" BorderThickness="1.5" Cursor="Hand" HorizontalAlignment="Center" Width="240"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}">
                            <Grid VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="24" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="LibreOffice" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="稳定版 26.2.4" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ROW 2: Segment Section Title -->
                <TextBlock Grid.Row="2" Text="选择需要包含的组件" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,15,0,8"
                           Visibility="{Binding IsMsOffice, Converter={StaticResource BoolToVisibility}}"/>

                <TextBlock Grid.Row="2" Text="部署及参数说明" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,15,0,8"
                           Visibility="{Binding IsWps, Converter={StaticResource BoolToVisibility}}"/>

                <TextBlock Grid.Row="2" Text="部署及参数说明" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,15,0,8"
                           Visibility="{Binding IsYozo, Converter={StaticResource BoolToVisibility}}"/>

                <TextBlock Grid.Row="2" Text="部署及参数说明" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,15,0,8"
                           Visibility="{Binding IsOnlyOffice, Converter={StaticResource BoolToVisibility}}"/>

                <TextBlock Grid.Row="2" Text="部署及参数说明" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,15,0,8"
                           Visibility="{Binding IsLibreOffice, Converter={StaticResource BoolToVisibility}}"/>

                <!-- ROW 3: Selection Panel or Info board -->
                <!-- MS Office Component Panel -->
                <Border Grid.Row="3" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Height="150"
                        Visibility="{Binding IsMsOffice, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Components}" Margin="20,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="10,5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- WPS Description Board -->
                <Border Grid.Row="3" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Height="150"
                        Visibility="{Binding IsWps, Converter={StaticResource BoolToVisibility}}">
                    <Grid Margin="20,15">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="• WPS 2019 专业增强版已适配 /NoCloud 纯净无云服务静默参数。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• WPS 2013/2016/2023 专业版已预设 /S 全自动静默部署参数。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• 专业增值版无内置广告干扰，适合高效纯净的本地办公环境。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Yozo Description Board -->
                <Border Grid.Row="3" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Height="150"
                        Visibility="{Binding IsYozo, Converter={StaticResource BoolToVisibility}}">
                    <Grid Margin="20,15">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="• 国内自主开发，集成式经典三合一界面，排版极度适配中文国标公文。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• 安装时使用 dl.yozosoft.com 官方直链 RAR 包并自动于后台解压静默安装。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• 避开官方主站 botstopper 浏览器盾拦截，全自动稳定拉取。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- OnlyOffice Description Board -->
                <Border Grid.Row="3" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Height="150"
                        Visibility="{Binding IsOnlyOffice, Converter={StaticResource BoolToVisibility}}">
                    <Grid Margin="20,15">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="• 开源强大的协作办公套件，其底层格式与 MS Office 达成最高度的一致兼容。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• 静默调用部署参数：/VERYSILENT /NORESTART" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• 终身免费，不含任何插件，支持多标签页式文档编辑体验。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- LibreOffice Description Board -->
                <Border Grid.Row="3" CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Height="150"
                        Visibility="{Binding IsLibreOffice, Converter={StaticResource BoolToVisibility}}">
                    <Grid Margin="20,15">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="• 著名开源基金会维护的顶级国际化办公套件，极度纯净且支持开放标准（ODF）。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• 基于 Windows Installer 引擎，静默指令：msiexec /i ... /qn /norestart" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                            <TextBlock Text="• 彻底告别商业版权与强制付费，中科大高可用镜像加速分发。" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ROW 4: Progress Info -->
                <StackPanel Grid.Row="4" Margin="0,10,0,10">
                    <ProgressBar Height="4" Minimum="0" Maximum="100"
                                 Value="{Binding DownloadProgress}"
                                 Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource BodyTextBlockStyle}" FontSize="12"
                               Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" TextAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- ROW 5: Bottom Buttons -->
                <Grid Grid.Row="5" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Targeted Deep Uninstaller (Red Accent) -->
                    <Button Grid.Column="1" Content="深层完全卸载" Command="{Binding UninstallCurrentCommand}" 
                            Width="160" Height="36" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource DefaultButtonStyle}"
                            Background="#B02525" Foreground="White" BorderThickness="0"
                            ui:ControlHelper.CornerRadius="6"/>

                    <!-- One-Click Deploy (Blue Accent) -->
                    <Button Grid.Column="3" Content="一键开始部署" Command="{Binding InstallCommand}" 
                            Width="160" Height="36" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource AccentButtonStyle}"
                            ui:ControlHelper.CornerRadius="6"/>
                </Grid>
            </Grid>
        </ui:NavigationView>
    </Grid>
</Window>
