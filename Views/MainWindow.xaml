<Window x:Class="GOI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:views="clr-namespace:GOI.Views"
        Title="Glim Office Installer"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Width="830"
        Height="730"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ui:ThemeManager.RequestedTheme="Default"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:TitleBar.IsIconVisible="True"
        Icon="pack://application:,,,/GOI;component/Resources/logo.png">

    <Window.Resources>
        <!-- Fluent 2.0 Borderless Icon Button Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SystemControlTransientBackgroundBrush}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SystemControlAltHighBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fluent 2.0 Critical/Warning Button Style -->
        <Style x:Key="CriticalButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="#C42B1C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="ui:ControlHelper.CornerRadius" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D3382B"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B32015"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource SystemControlDisabledBaseLowBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SystemControlDisabledBaseMediumLowBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- Native Fluent NavigationView for Left Menu -->
        <ui:NavigationView x:Name="NavView"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="True"
                           OpenPaneLength="190"
                           SelectionChanged="NavigationView_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="{Binding Loc.NavMsOffice}" Tag="MsOffice">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/ms_office_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{Binding Loc.NavWps}" Tag="Wps">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/wps_office_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{Binding Loc.NavYozo}" Tag="Yozo">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/yozo_office_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{Binding Loc.NavOnlyOffice}" Tag="OnlyOffice">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/onlyoffice_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{Binding Loc.NavLibreOffice}" Tag="LibreOffice">
                    <ui:NavigationViewItem.Icon>
                        <Image Source="pack://application:,,,/GOI;component/Resources/libreoffice_logo.png" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <Grid Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- ROW 0: Common Header & InfoBar -->
                    <RowDefinition Height="*"/>    <!-- ROW 1: Content Area (Dynamic by software) -->
                    <RowDefinition Height="Auto"/> <!-- ROW 2: Common Progress Info -->
                    <RowDefinition Height="Auto"/> <!-- ROW 3: Common Action Buttons -->
                </Grid.RowDefinitions>

                <!-- ROW 0: Header & Installed Detection InfoBar -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Header Icon (Dynamic Software Logo / Glim Logo) -->
                        <Image Grid.Column="0" Source="{Binding HeaderIconPath}" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <!-- Header Title -->
                        <TextBlock Grid.Column="1" Text="{Binding HeaderTitleText}" Style="{StaticResource TitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                    
                    <!-- Native Fluent Warning InfoBar -->
                    <ui:InfoBar Title="{Binding Loc.InstalledDetected}"
                                Message="{Binding InstalledVersionText}"
                                IsOpen="{Binding IsInstalledWarningVisible}"
                                Severity="Warning"
                                IsClosable="False"
                                Margin="0,0,0,5"/>
                </StackPanel>

                <!-- ROW 1: Content Area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
                    <Grid Margin="0,10,12,10">
                    
                    <!-- 1. Microsoft Office Page -->
                    <StackPanel Visibility="{Binding IsMsOffice, Converter={StaticResource BoolToVisibility}}">
                        <!-- Section title -->
                        <TextBlock Text="{Binding Loc.SelectVersion}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"/>
                        
                        <!-- Office 2024 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Office2024Title}" Description="{Binding Loc.Office2024Desc}" IsSelected="{Binding Office2024Selected}" Command="{Binding SelectOffice2024Command}" IsEnabled="{Binding IsModernOfficeSupported}"/>

                        <!-- Microsoft 365 -->
                        <views:VersionCard IconGlyph="&#xE753;" Title="{Binding Loc.M365Title}" Description="{Binding Loc.M365Desc}" IsSelected="{Binding M365Selected}" Command="{Binding SelectM365Command}" IsEnabled="{Binding IsModernOfficeSupported}"/>

                        <!-- Office 2021 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Office2021Title}" Description="{Binding Loc.Office2021Desc}" IsSelected="{Binding Office2021Selected}" Command="{Binding SelectOffice2021Command}" IsEnabled="{Binding IsModernOfficeSupported}"/>

                        <!-- Office 2019 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Office2019Title}" Description="{Binding Loc.Office2019Desc}" IsSelected="{Binding Office2019Selected}" Command="{Binding SelectOffice2019Command}" IsEnabled="{Binding IsModernOfficeSupported}"/>

                        <!-- Office 2016 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Office2016Title}" Description="{Binding Loc.Office2016Desc}" IsSelected="{Binding Office2016Selected}" Command="{Binding SelectOffice2016Command}"/>

                        <!-- Advanced Options -->
                        <TextBlock Text="{Binding Loc.AdvancedOptions}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,18,0,8"/>

                        <!-- Update Channel Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE8B6;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.LabelUpdateChannel}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.LabelUpdateChannelDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="180" VerticalAlignment="Center" SelectedValuePath="Tag" SelectedValue="{Binding SelectedUpdateChannel, Mode=TwoWay}">
                                    <ComboBoxItem Content="{Binding Loc.ChannelCurrent}" Tag="Current"/>
                                    <ComboBoxItem Content="{Binding Loc.ChannelCurrentPreview}" Tag="CurrentPreview"/>
                                    <ComboBoxItem Content="{Binding Loc.ChannelMonthlyEnterprise}" Tag="MonthlyEnterprise"/>
                                    <ComboBoxItem Content="{Binding Loc.ChannelSemiAnnual}" Tag="SemiAnnual"/>
                                    <ComboBoxItem Content="{Binding Loc.ChannelSemiAnnualPreview}" Tag="SemiAnnualPreview"/>
                                    <ComboBoxItem Content="{Binding Loc.ChannelBeta}" Tag="BetaChannel"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Office Language Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE774;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.LabelLanguage}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.LabelLanguageDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="180" VerticalAlignment="Center" 
                                          IsEditable="True"
                                          Text="{Binding SelectedOfficeLanguage, Mode=TwoWay}">
                                    <ComboBoxItem Content="zh-cn (简体中文)"/>
                                    <ComboBoxItem Content="zh-tw (繁體中文)"/>
                                    <ComboBoxItem Content="zh-hk (繁體中文 - 香港)"/>
                                    <ComboBoxItem Content="en-us (English - US)"/>
                                    <ComboBoxItem Content="en-gb (English - UK)"/>
                                    <ComboBoxItem Content="ja-jp (日本語)"/>
                                    <ComboBoxItem Content="ko-kr (한국어)"/>
                                    <ComboBoxItem Content="fr-fr (Français)"/>
                                    <ComboBoxItem Content="de-de (Deutsch)"/>
                                    <ComboBoxItem Content="es-es (Español)"/>
                                    <ComboBoxItem Content="it-it (Italiano)"/>
                                    <ComboBoxItem Content="ru-ru (Русский)"/>
                                    <ComboBoxItem Content="pt-br (Português - Brasil)"/>
                                    <ComboBoxItem Content="pt-pt (Português - Portugal)"/>
                                    <ComboBoxItem Content="ar-sa (العربية)"/>
                                    <ComboBoxItem Content="th-th (ไทย)"/>
                                    <ComboBoxItem Content="vi-vn (Tiếng Việt)"/>
                                    <ComboBoxItem Content="tr-tr (Türkçe)"/>
                                    <ComboBoxItem Content="pl-pl (Polski)"/>
                                    <ComboBoxItem Content="nl-nl (Nederlands)"/>
                                    <ComboBoxItem Content="sv-se (Svenska)"/>
                                    <ComboBoxItem Content="no-no (Norsk)"/>
                                    <ComboBoxItem Content="da-dk (Dansk)"/>
                                    <ComboBoxItem Content="fi-fi (Suomi)"/>
                                    <ComboBoxItem Content="uk-ua (Українська)"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Architecture Bitness Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE950;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.LabelBitness}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.LabelBitnessDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="180" VerticalAlignment="Center" SelectedValuePath="Tag" SelectedValue="{Binding SelectedBitness, Mode=TwoWay}">
                                    <ComboBoxItem Content="{Binding Loc.Bit64}" Tag="64" IsEnabled="{Binding Is64BitOperatingSystem}"/>
                                    <ComboBoxItem Content="{Binding Loc.Bit32}" Tag="32"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Export XML Card (Visible when enabled in Settings) -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow"
                                Visibility="{Binding IsExportXmlButtonVisible, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsExportXmlTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsExportXmlDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnExportXml}" Command="{Binding ExportXmlCommand}"
                                        Width="180" VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Components Header -->
                        <TextBlock Text="{Binding Loc.SelectComponents}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,18,0,8"/>

                        <ItemsControl ItemsSource="{Binding Components}" Margin="12,4,12,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="10,8" FontSize="13"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 2. WPS Office Page -->
                    <StackPanel Visibility="{Binding IsWps, Converter={StaticResource BoolToVisibility}}">
                        <!-- Section title -->
                        <TextBlock Text="{Binding Loc.SelectVersion}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"/>
                        
                        <!-- WPS Latest -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.WpsLatestTitle}" Description="{Binding Loc.WpsLatestDesc}" IsSelected="{Binding WpsLatestSelected}" Command="{Binding SelectWpsLatestCommand}"/>

                        <!-- WPS 2023 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Wps2023Title}" Description="{Binding Loc.Wps2023Desc}" IsSelected="{Binding Wps2023Selected}" Command="{Binding SelectWps2023Command}"/>

                        <!-- WPS 2019 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Wps2019Title}" Description="{Binding Loc.Wps2019Desc}" IsSelected="{Binding Wps2019Selected}" Command="{Binding SelectWps2019Command}"/>

                        <!-- WPS 2016 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Wps2016Title}" Description="{Binding Loc.Wps2016Desc}" IsSelected="{Binding Wps2016Selected}" Command="{Binding SelectWps2016Command}"/>

                        <!-- WPS 2013 -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.Wps2013Title}" Description="{Binding Loc.Wps2013Desc}" IsSelected="{Binding Wps2013Selected}" Command="{Binding SelectWps2013Command}"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{Binding Loc.DeployAndParams}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,18,0,8"/>

                        <!-- WPS Description Cards List -->
                        <StackPanel>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE896;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.WpsParam1Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.WpsParam1Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE73A;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.WpsParam2Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.WpsParam2Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.WpsParam3Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.WpsParam3Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- 3. Yozo Office Page -->
                    <StackPanel Visibility="{Binding IsYozo, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Loc.SelectVersion}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"/>
                        
                        <!-- Yozo Card -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.YozoTitle}" Description="{Binding Loc.YozoDesc}" IsSelected="True" Command="{Binding SelectYozoPersonalCommand}"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{Binding Loc.DeployAndParams}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,18,0,8"/>

                        <!-- Yozo Description Cards List -->
                        <StackPanel>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.YozoParam1Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.YozoParam1Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE896;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.YozoParam2Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.YozoParam2Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- 4. OnlyOffice Page -->
                    <StackPanel Visibility="{Binding IsOnlyOffice, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Loc.SelectVersion}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"/>
                        
                        <!-- OnlyOffice Card -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.OnlyOfficeTitle}" Description="{Binding Loc.OnlyOfficeDesc}" IsSelected="True" Command="{Binding SelectOnlyOfficeDesktopCommand}" IsEnabled="{Binding IsOnlyOfficeSupported}"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{Binding Loc.DeployAndParams}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,18,0,8"/>

                        <!-- OnlyOffice Description Cards List -->
                        <StackPanel>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.OnlyOfficeParam1Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.OnlyOfficeParam1Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE9A6;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.OnlyOfficeParam2Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.OnlyOfficeParam2Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- 5. LibreOffice Page -->
                    <StackPanel Visibility="{Binding IsLibreOffice, Converter={StaticResource BoolToVisibility}}">
                        <!-- Section title -->
                        <TextBlock Text="{Binding Loc.SelectVersion}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"/>
                        
                        <!-- LibreOffice Card -->
                        <views:VersionCard IconGlyph="&#xE7C3;" Title="{Binding Loc.LibreOfficeTitle}" Description="{Binding Loc.LibreOfficeDesc}" IsSelected="True" Command="{Binding SelectLibreOfficeStableCommand}" IsEnabled="{Binding IsLibreOfficeSupported}"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{Binding Loc.DeployAndParams}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,18,0,8"/>

                        <!-- LibreOffice Description Cards List -->
                        <StackPanel>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE9A1;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.LibreOfficeParam1Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.LibreOfficeParam1Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xEC05;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Loc.LibreOfficeParam2Title}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Loc.LibreOfficeParam2Desc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- 6. Settings Page -->
                    <StackPanel Visibility="{Binding IsSettings, Converter={StaticResource BoolToVisibility}}">
                        <!-- Section title -->
                        <TextBlock Text="{Binding Loc.SettingsPersonalization}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" FontWeight="SemiBold" Margin="4,0,0,8"/>

                        <!-- Theme Setting Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE771;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsThemeTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsThemeDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="120" VerticalAlignment="Center" SelectedValuePath="Tag" SelectedValue="{Binding SelectedTheme, Mode=TwoWay}">
                                    <ComboBoxItem Content="{Binding Loc.ThemeSystem}" Tag="Default"/>
                                    <ComboBoxItem Content="{Binding Loc.ThemeLight}" Tag="Light"/>
                                    <ComboBoxItem Content="{Binding Loc.ThemeDark}" Tag="Dark"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Language Setting Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE774;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsLanguageTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsLanguageDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="120" VerticalAlignment="Center" SelectedValuePath="Tag" SelectedValue="{Binding SelectedAppLanguage, Mode=TwoWay}">
                                    <ComboBoxItem Content="简体中文" Tag="SimplifiedChinese"/>
                                    <ComboBoxItem Content="繁體中文" Tag="TraditionalChinese"/>
                                    <ComboBoxItem Content="English" Tag="English"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Section title: Office Cleanup -->
                        <TextBlock Text="{Binding Loc.SettingsCleanupSectionTitle}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,12,0,8"/>

                        <!-- Uninstall Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="#B02525" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsUninstallTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsUninstallDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="180" VerticalAlignment="Center" SelectedValuePath="Tag" SelectedValue="{Binding ProductTypeToUninstall, Mode=TwoWay}">
                                    <ComboBoxItem Content="Microsoft Office" Tag="MsOffice"/>
                                    <ComboBoxItem Content="WPS Office" Tag="Wps"/>
                                    <ComboBoxItem Content="{Binding Loc.YozoTitle}" Tag="Yozo"/>
                                    <ComboBoxItem Content="OnlyOffice" Tag="OnlyOffice"/>
                                    <ComboBoxItem Content="LibreOffice" Tag="LibreOffice"/>
                                </ComboBox>
                                <Button Grid.Column="4" Content="{Binding Loc.BtnUninstall}" Command="{Binding UninstallSelectedCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource CriticalButtonStyle}"/>
                            </Grid>
                        </Border>
                        <!-- Office 授权与注册表工具 -->
                        <TextBlock Text="{Binding Loc.SettingsLicenseSectionTitle}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,12,0,8"/>

                        <!-- License Clear Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,8" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE72D;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsClearLicenseTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsClearLicenseDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnClearLicense}" Command="{Binding ClearOfficeActivationCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"/>
                            </Grid>
                        </Border>


                        <!-- Ohook License Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE9AC;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsOhookTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsOhookDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnActivate}" Command="{Binding ActivateOfficeOhookCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource AccentButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- 文件关联与图标净化工具 -->
                        <TextBlock Text="{Binding Loc.SettingsFileAssociationSectionTitle}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,12,0,8"/>

                        <!-- File Association Repair Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE71B;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsCleanAssociationsTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsCleanAssociationsDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnCleanAssociations}" Command="{Binding CleanOrphanedAssociationsCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Refresh Icon Cache Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xEC07;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsRefreshIconCacheTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsRefreshIconCacheDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnRefreshIconCache}" Command="{Binding RefreshIconCacheCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Repair File Associations Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE815;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsRepairAssociationsTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsRepairAssociationsDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnRepairAssociations}" Command="{Binding RepairAssociationsCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Repair COM Components Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE90F;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsRepairCOMTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsRepairCOMDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnRepairCOM}" Command="{Binding RepairCOMCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Debug Tools -->
                        <TextBlock Text="{Binding Loc.SettingsDebugSectionTitle}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,12,0,8"/>

                        <!-- Enable Export XML Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsEnableExportXmlTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsEnableExportXmlDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="2" IsOn="{Binding IsExportXmlEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" HorizontalAlignment="Right" MinWidth="0" OnContent="{Binding Loc.LabelOn}" OffContent="{Binding Loc.LabelOff}"/>
                            </Grid>
                        </Border>

                        <!-- Export XML Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsExportXmlTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsExportXmlDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnExportXml}" Command="{Binding ExportXmlCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Open Log Folder Card -->
                        <Border Style="{StaticResource FluentCardBaseStyle}" Margin="0,0,0,12" Cursor="Arrow">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE8B7;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Loc.SettingsOpenLogFolderTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Loc.SettingsOpenLogFolderDesc}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Loc.BtnOpenLogFolder}" Command="{Binding OpenLogFolderCommand}"
                                        VerticalAlignment="Center" Padding="15,5"
                                        Style="{StaticResource DefaultButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- About Section title -->
                        <TextBlock Text="{Binding Loc.SettingsAboutSectionTitle}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="4,12,0,8"/>

                        <!-- About Card -->
                        <Border CornerRadius="8" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <Grid Margin="20,15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="pack://application:,,,/GOI;component/Resources/logo.png" Width="32" Height="32" VerticalAlignment="Center" HorizontalAlignment="Left" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Loc.AppTitle}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" FontSize="14" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                <TextBlock Text="{Binding Loc.AppVersion}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12"/>
                                                <TextBlock Text="    " FontSize="12"/>
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" FontSize="12">
                                                    <Hyperlink Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/WumiaoTech228" TextDecorations="None" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}">
                                                        <TextBlock Text="{Binding Loc.AboutAuthor}"/>
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Margin="0,3,0,0" Style="{StaticResource CaptionTextBlockStyle}" FontSize="12">
                                                <Hyperlink Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/WumiaoTech228/GlimOfficeInstaller" TextDecorations="None" Foreground="{DynamicResource SystemControlHighlightAccentBrush}">
                                                    <Run Text="GitHub: github.com/WumiaoTech228/GlimOfficeInstaller"/>
                                                </Hyperlink>
                                            </TextBlock>
                                            <TextBlock Margin="0,3,0,0" Style="{StaticResource CaptionTextBlockStyle}" FontSize="12">
                                                <Hyperlink Command="{Binding OpenUrlCommand}" CommandParameter="https://blog.110228.xyz" TextDecorations="None" Foreground="{DynamicResource SystemControlHighlightAccentBrush}">
                                                    <Run Text="Blog: blog.110228.xyz"/>
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding Loc.AboutDesc1}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Loc.AboutDesc2}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" FontSize="12.5" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

                <!-- ROW 2: Common Progress Info -->
                <StackPanel Grid.Row="2" Margin="0,10,28,10" Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar Height="4" Minimum="0" Maximum="100"
                                 Value="{Binding DownloadProgress}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource BodyTextBlockStyle}" FontSize="12"
                               Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Left" Margin="4,6,0,0"/>
                </StackPanel>

                <!-- ROW 3: Common Action Buttons -->
                <Grid Grid.Row="3" Margin="0,0,28,10" Visibility="{Binding IsActionButtonsVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- One-Click Deploy (Blue Accent) -->
                    <Button Grid.Column="1" Content="{Binding Loc.BtnDeploy}" Command="{Binding InstallCommand}" 
                            Width="160" Height="36" FontSize="14"
                            Style="{StaticResource AccentButtonStyle}"/>
                </Grid>
            </Grid>
            </ui:NavigationView>

        </Grid>
    </Window>

